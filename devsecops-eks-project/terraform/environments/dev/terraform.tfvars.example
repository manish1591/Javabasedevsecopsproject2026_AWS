cat > /d/Devsecopsrepos/devsecops-eks-project/terraform/environments/dev/terraform.tfvars.example << 'EOF'
# Copy this file to terraform.tfvars and update values
# DO NOT commit terraform.tfvars to git (contains secrets)

aws_region     = "us-east-1"
environment    = "dev"
project_name   = "devsecops-demo"

# Network configuration
vpc_cidr               = "10.0.0.0/16"
availability_zones     = ["us-east-1a", "us-east-1b", "us-east-1c"]
public_subnet_cidrs    = ["10.0.1.0/24", "10.0.2.0/24", "10.0.3.0/24"]
private_subnet_cidrs   = ["10.0.4.0/24", "10.0.5.0/24", "10.0.6.0/24"]
enable_nat_gateway     = true

# EKS configuration
kubernetes_version              = "1.28"
cluster_endpoint_public_access  = false
cluster_endpoint_private_access = true
node_instance_types             = ["t3.micro", "t3.small"]
node_desired_size               = 2
node_min_size                   = 1
node_max_size                   = 4

# Security configuration
enable_kms_encryption   = true
enable_guardduty       = false  # Enable for production
enable_secrets_manager = false  # Use Vault instead
EOF
