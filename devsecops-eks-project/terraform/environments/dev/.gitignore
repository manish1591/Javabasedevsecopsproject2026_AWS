cat > /d/Devsecopsrepos/devsecops-eks-project/terraform/.gitignore << 'EOF'
# Local .terraform directories
**/.terraform/*
*.terraform

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files (contain sensitive data)
*.tfvars
*.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

# Terragrunt
**/.terragrunt*

# Local secrets
**/terraform.tfvars
**/terraform.tfvars.json

# Backup files
*.backup
*.bak
*.swp

# Plan files
*.plan
*.out
EOF

